---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import BlogPostCard from '../components/BlogPostCard.astro';

const posts = (await getCollection('blog', ({ data }) => {
	return data.draft !== true;
}))
.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
.slice(0, 3); // Display only top 3 recent posts
---

<Layout title="박규태 | Math, Stats & Tech Blog" description="수학, 통계학, 데이터 분석 및 소프트웨어 개발을 다루는 박규태의 블로그입니다.">
	<div class="home-grid">
		<!-- Left: Profile Sidebar (Sticky on Desktop) -->
		<aside class="profile-sidebar animate-fade-in">
			<div class="sidebar-avatar">
				<img src="/avatar.png" alt="박규태" style="width: 100%; height: 100%; object-fit: cover; border-radius: 50%;" />
			</div>
			<div>
				<h1 class="sidebar-name">박규태</h1>
				<p class="sidebar-title">Math • Stats • Tech</p>
			</div>
			<p class="sidebar-bio">
				수학과 통계학, 그리고 테크놀로지를 다루는 공간입니다.
				복잡한 현상을 정량적으로 모델링하고, 통계적 추론을 통해 데이터 이면의 진실을 탐구하며, 
				이를 확장 가능하고 견고한 소프트웨어로 구현하는 것에 열정을 지니고 있습니다.
			</p>
			<nav class="sidebar-socials" aria-label="Social links">
				<a href="https://github.com/park-gyutae" target="_blank" rel="noopener noreferrer">
					GitHub
					<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
						<path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
						<polyline points="15 3 21 3 21 9"></polyline>
						<line x1="10" y1="14" x2="21" y2="3"></line>
					</svg>
				</a>
				<a href="https://scholar.google.com" target="_blank" rel="noopener noreferrer">
					Google Scholar
					<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
						<path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
						<polyline points="15 3 21 3 21 9"></polyline>
						<line x1="10" y1="14" x2="21" y2="3"></line>
					</svg>
				</a>
				<a href="mailto:gyutae.q.park@gmail.com">Email</a>
			</nav>
		</aside>

		<!-- Right: Main Content -->
		<div class="main-content-area animate-fade-in" style="animation-delay: 0.1s;">
			<!-- Recent Posts -->
			<section class="recent-posts-section">
				<div class="recent-posts-header">
					<h2 class="section-title">Recent Posts</h2>
					<a href="/blog" class="all-posts-link">모든 글 보기 →</a>
				</div>

				{posts.length === 0 ? (
					<div class="no-posts">
						<p>등록된 포스트가 없습니다.</p>
					</div>
				) : (
					<div class="posts-list-vertical">
						{posts.map((post) => (
							<BlogPostCard post={post} />
						))}
					</div>
				)}
			</section>

			<!-- Focus Areas -->
			<section class="focus-section" style="margin-top: 3.5rem;">
				<h2 class="section-title" style="margin-bottom: 1.5rem; border-bottom: 1px solid var(--border-color); padding-bottom: 0.5rem;">Focus Areas</h2>
				<div class="focus-vertical-list">
					<div class="focus-item">
						<h3 class="focus-item-title">Mathematics & Stats</h3>
						<p class="focus-item-desc">선형대수학, 다변량해석, 수치 최적화, 베이지안 통계 및 가설 검정을 통한 정량적 모델 수립</p>
					</div>
					<div class="focus-item">
						<h3 class="focus-item-title">Machine Learning</h3>
						<p class="focus-item-desc">딥러닝 모델 아키텍처 구현, 통계적 학습 이론 연구, 알고리즘 맞춤 커스터마이징</p>
					</div>
					<div class="focus-item">
						<h3 class="focus-item-title">Software Engineering</h3>
						<p class="focus-item-desc">Python 및 R 분석 가용 환경 인프라 설계, 견고한 데이터 파이프라인 및 백엔드 서비스 개발</p>
					</div>
				</div>
			</section>
		</div>
	</div>
</Layout>

<style>
	.main-content-area {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.posts-list-vertical {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.no-posts {
		text-align: center;
		padding: 3rem 0;
		color: var(--text-muted);
		background-color: var(--card-bg);
		border: 1px dashed var(--border-color);
		border-radius: 0.5rem;
	}

	/* Focus Items */
	.focus-vertical-list {
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
	}

	.focus-item {
		border-left: 2px solid var(--border-color);
		padding-left: 1.25rem;
		transition: border-color var(--transition-speed) ease;
	}

	.focus-item:hover {
		border-left-color: var(--primary-color);
	}

	.focus-item-title {
		font-size: 1.1rem;
		font-weight: 700;
		color: var(--text-color);
		margin-bottom: 0.25rem;
	}

	.focus-item-desc {
		font-size: 0.92rem;
		color: var(--text-muted);
		line-height: 1.6;
		margin-bottom: 0;
	}
</style>
