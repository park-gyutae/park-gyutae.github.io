---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import BlogPostCard from '../components/BlogPostCard.astro';

const posts = (await getCollection('blog', ({ data }) => {
	return data.draft !== true;
}))
.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
.slice(0, 3); // Display only top 3 recent posts
---

<Layout title="박규태 | Math, Stats & Tech Blog" description="수학, 통계학, 데이터 분석 및 소프트웨어 개발을 다루는 박규태의 블로그입니다.">
	<!-- About / Bio Section -->
	<section class="about-section">
		<div class="profile-header">
			<div class="avatar-container">
				<svg width="60" height="60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
					<path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
					<circle cx="12" cy="7" r="4"></circle>
				</svg>
			</div>
			<div>
				<h1 class="profile-name">박규태 (Park Gyutae)</h1>
				<p class="profile-title">Mathematics • Statistics • Tech</p>
			</div>
		</div>

		<div class="bio-content">
			<p>
				안녕하세요! 수학과 통계학, 그리고 테크놀로지를 다루는 공간입니다.
				복잡한 현상을 정량적으로 모델링하고, 통계적 추론을 통해 데이터 이면의 진실을 탐구하며, 
				이를 확장 가능하고 견고한 소프트웨어로 구현하는 것에 열정을 지니고 있습니다.
			</p>
			<p>
				수치적 최적화, 기계 학습 알고리즘, 확률 모형 설계부터 백엔드 및 데이터 엔지니어링 파이프라인 구축까지 
				경계를 넘나들며 배우고 성장하고 있습니다. 이 블로그에는 공부하며 깊게 고민한 생각의 파편과 증명, 
				프로젝트의 여정들을 차분히 기록해 나가고자 합니다.
			</p>
		</div>

		<div class="focus-areas">
			<h2 class="section-subtitle">Focus Areas</h2>
			<div class="focus-grid">
				<div class="focus-card">
					<h3>Mathematics & Stats</h3>
					<p>선형대수학, 다변량해석, 수치 최적화, 베이지안 통계 및 가설 검정</p>
				</div>
				<div class="focus-card">
					<h3>Machine Learning</h3>
					<p>딥러닝 모델 아키텍처, 통계적 학습 이론, 알고리즘 커스터마이징</p>
				</div>
				<div class="focus-card">
					<h3>Software Engineering</h3>
					<p>Python/R 기반의 분석 환경 설계, 데이터 파이프라인, 백엔드 아키텍처</p>
				</div>
			</div>
		</div>
	</section>

	<hr class="section-divider" />

	<!-- Recent Posts Section -->
	<section class="recent-posts-section">
		<div class="section-header">
			<h2 class="section-title">최근 게시글</h2>
			<a href="/blog" class="all-posts-link">
				<span>모든 글 보기</span>
				<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
					<line x1="5" y1="12" x2="19" y2="12"></line>
					<polyline points="12 5 19 12 12 19"></polyline>
				</svg>
			</a>
		</div>

		{posts.length === 0 ? (
			<div class="no-posts">
				<p>등록된 포스트가 없습니다.</p>
			</div>
		) : (
			<div class="posts-grid">
				{posts.map((post) => (
					<BlogPostCard post={post} />
				))}
			</div>
		)}
	</section>
</Layout>

<style>
	/* About Section */
	.about-section {
		padding: 2rem 0;
	}

	.profile-header {
		display: flex;
		align-items: center;
		gap: 1.5rem;
		margin-bottom: 2rem;
	}

	.avatar-container {
		width: 80px;
		height: 80px;
		border-radius: 50%;
		background-color: var(--border-color);
		color: var(--text-color);
		display: flex;
		align-items: center;
		justify-content: center;
		border: 1px solid var(--border-color);
	}

	.profile-name {
		font-size: 2.25rem;
		font-weight: 800;
		line-height: 1.1;
		margin-bottom: 0.25rem;
	}

	.profile-title {
		font-size: 1.1rem;
		font-weight: 600;
		color: var(--primary-color);
	}

	.bio-content p {
		font-size: 1.05rem;
		line-height: 1.8;
		color: var(--text-color);
		margin-bottom: 1.25rem;
	}

	.section-subtitle {
		font-size: 1.5rem;
		font-weight: 700;
		margin-top: 2.5rem;
		margin-bottom: 1.25rem;
		border-bottom: 1px solid var(--border-color);
		padding-bottom: 0.5rem;
	}

	.focus-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1rem;
	}

	@media (min-width: 768px) {
		.focus-grid {
			grid-template-columns: repeat(3, 1fr);
		}
	}

	.focus-card {
		background-color: var(--card-bg);
		border: 1px solid var(--border-color);
		border-radius: 0.5rem;
		padding: 1.25rem;
		box-shadow: var(--card-shadow);
	}

	.focus-card h3 {
		font-size: 1.1rem;
		font-weight: 700;
		color: var(--primary-color);
		margin-bottom: 0.5rem;
	}

	.focus-card p {
		font-size: 0.95rem;
		color: var(--text-muted);
		margin-bottom: 0;
		line-height: 1.5;
	}

	.section-divider {
		border: none;
		border-top: 1px solid var(--border-color);
		margin: 3rem 0;
	}

	/* Recent Posts */
	.recent-posts-section {
		margin-bottom: 2rem;
	}

	.section-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 1.75rem;
	}

	.section-title {
		font-size: 1.75rem;
		font-weight: 800;
	}

	.all-posts-link {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		font-weight: 700;
		font-size: 0.95rem;
		color: var(--primary-color);
		transition: color var(--transition-speed) ease;
	}

	.all-posts-link svg {
		transition: transform var(--transition-speed) ease;
	}

	.all-posts-link:hover svg {
		transform: translateX(4px);
	}

	.posts-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1.5rem;
	}

	@media (min-width: 640px) {
		.posts-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (min-width: 768px) {
		.posts-grid {
			/* If there are 3 posts, let's keep grid dynamic or show 2/3 */
			grid-template-columns: repeat(2, 1fr);
		}
	}

	.no-posts {
		text-align: center;
		padding: 3rem 0;
		color: var(--text-muted);
		background-color: var(--card-bg);
		border: 1px dashed var(--border-color);
		border-radius: 0.5rem;
	}
</style>
