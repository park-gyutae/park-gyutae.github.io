---
import Layout from '../layouts/Layout.astro';

interface Project {
  title: string;
  category: string;
  description: string;
  tags: string[];
  links: {
    github?: string;
    demo?: string;
  };
}

const projects: Project[] = [
  {
    title: "베이지안 회귀 분석 기반 마케팅 믹스 모델링 (MMM)",
    category: "Statistics & Modeling",
    description: "R과 Stan을 활용하여 다매체 광고 집행비가 매출에 미치는 지연 효과(Adstock) 및 포화 현상(Saturation)을 베이지안 마크로 레벨 회귀 모형으로 모델링하고 최적의 예산 배분 전략을 산출했습니다.",
    tags: ["R", "Stan", "Bayesian", "ggplot2"],
    links: {
      github: "https://github.com",
    }
  },
  {
    title: "하이브리드 LSTM-Transformer 시계열 예측 모델",
    category: "Deep Learning",
    description: "PyTorch를 사용하여 복잡한 계절성과 장기 의존성을 가지는 대규모 시계열 전력 소비 데이터를 정밀하게 예측하기 위해 LSTM의 로컬 맥락 특징 추출과 Transformer의 셀프 어텐션을 결합한 하이브리드 아키텍처를 구현했습니다.",
    tags: ["Python", "PyTorch", "TimeSeries", "Pandas"],
    links: {
      github: "https://github.com",
      demo: "https://github.com"
    }
  },
  {
    title: "학술 및 테크 최적화 정적 블로그 엔진",
    category: "Web & Frontend",
    description: "Astro v4 프레임워크와 remark-math/rehype-katex 플러그인을 결합하여 수학 공식과 코드를 빌드 타임에 정적 HTML로 완벽히 사전 컴파일하는 고성능 블로그 엔진을 설계하고 GitHub Pages에 배포 환경을 구축했습니다.",
    tags: ["Astro", "TypeScript", "LaTeX", "CSS"],
    links: {
      github: "https://github.com/park-gyutae/park-gyutae.github.io",
      demo: "https://park-gyutae.github.io"
    }
  }
];
---

<Layout title="프로젝트 | DevLog" description="박규태의 통계 분석, 데이터 모델링 및 소프트웨어 개발 프로젝트 아카이브입니다.">
  <section class="page-header">
    <h1 class="page-title">프로젝트</h1>
    <p class="page-subtitle">학술 연구, 통계 분석, 데이터 모델링 및 테크 개발 프로젝트 모음입니다.</p>
  </section>

  <section class="projects-section">
    <div class="projects-grid">
      {projects.map((project) => (
        <article class="project-card">
          <div class="card-meta">
            <span class="category-badge">{project.category}</span>
          </div>
          <h2 class="project-title">{project.title}</h2>
          <p class="project-desc">{project.description}</p>
          <div class="project-tags">
            {project.tags.map((tag) => (
              <span class="tag-badge">#{tag}</span>
            ))}
          </div>
          <div class="project-links">
            {project.links.github && (
              <a href={project.links.github} target="_blank" rel="noopener noreferrer" class="link-btn" aria-label="GitHub Repository">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path>
                </svg>
                <span>Code</span>
              </a>
            )}
            {project.links.demo && (
              <a href={project.links.demo} target="_blank" rel="noopener noreferrer" class="link-btn" aria-label="Live Demo">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                  <polyline points="15 3 21 3 21 9"></polyline>
                  <line x1="10" y1="14" x2="21" y2="3"></line>
                </svg>
                <span>Demo</span>
              </a>
            )}
          </div>
        </article>
      ))}
    </div>
  </section>
</Layout>

<style>
  .page-header {
    padding: 2rem 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    border-bottom: 1px solid var(--border-color);
    margin-bottom: 2.5rem;
  }

  .page-title {
    font-size: 2.5rem;
    font-weight: 800;
  }

  .page-subtitle {
    font-size: 1.1rem;
    color: var(--text-muted);
  }

  /* Projects Grid */
  .projects-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 768px) {
    .projects-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .project-card {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 0.75rem;
    padding: 1.75rem;
    box-shadow: var(--card-shadow);
    transition: all var(--transition-speed) ease;
    display: flex;
    flex-direction: column;
  }

  .project-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--card-hover-shadow);
    border-color: var(--primary-color);
  }

  .category-badge {
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--primary-color);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .project-title {
    font-size: 1.35rem;
    font-weight: 800;
    margin-top: 0.5rem;
    margin-bottom: 0.75rem;
    line-height: 1.3;
  }

  .project-desc {
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
    margin-top: auto;
  }

  .tag-badge {
    font-size: 0.8rem;
    font-weight: 600;
    padding: 0.2rem 0.5rem;
    background-color: var(--border-color);
    color: var(--text-muted);
    border-radius: 0.25rem;
  }

  .project-links {
    display: flex;
    gap: 1rem;
  }

  .link-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--text-color);
    border: 1px solid var(--border-color);
    padding: 0.4rem 0.75rem;
    border-radius: 0.5rem;
    transition: all var(--transition-speed) ease;
  }

  .link-btn:hover {
    background-color: var(--primary-color);
    color: #ffffff;
    border-color: var(--primary-color);
  }
</style>
