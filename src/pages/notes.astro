---
import Layout from '../layouts/Layout.astro';

interface Note {
  date: string;
  content: string;
  tags?: string[];
}

const notes: Note[] = [
  {
    date: "2026-07-02",
    content: "중심극한정리(CLT)는 모집단의 분포 형태와 상관없이 표본의 크기 n이 커짐에 따라 표본평균의 분포가 정규분포에 수렴한다는 점에서 매우 경이롭습니다. 확률론에서 가장 아름다운 보편성(universality) 클래스 중 하나라고 생각합니다.",
    tags: ["Probability", "Math"]
  },
  {
    date: "2026-07-01",
    content: "블로그에 remark-math와 rehype-katex를 통합하여 수학 공식 빌드타임 컴파일 환경을 완성했습니다. 클라이언트 사이드 자바스크립트 없이 정적으로 수식을 미리 렌더링함으로써 블로그의 로딩 성능(Total Blocking Time)을 크게 개선할 수 있어 뿌듯합니다.",
    tags: ["Astro", "Webdev"]
  },
  {
    date: "2026-06-28",
    content: "회귀분석 시 다중공선성(Multicollinearity) 문제가 보일 때는 무작정 변수를 제거하기보다 Ridge나 Lasso 같은 정규화(Regularization) 기법을 쓰거나, 도메인 지식을 바탕으로 변수들을 결합하여 의미 있는 합성 변수를 만드는 것이 해석과 예측 성능 양쪽 모두에 이로울 때가 많습니다.",
    tags: ["Statistics", "Regression"]
  }
];
---

<Layout title="Notes | park-gyutae" description="짧은 생각들, 유용한 메모, 생각나는 아이디어를 기록해두는 공간입니다.">
  <section class="page-header">
    <h1 class="page-title">Notes</h1>
    <p class="page-subtitle">정리된 논문이나 포스트는 아니지만, 공부하며 떠오른 짧은 생각들과 메모들의 아카이브입니다.</p>
  </section>

  <section class="notes-section">
    <div class="timeline">
      {notes.map((note) => (
        <div class="timeline-item">
          <div class="timeline-date">
            <time>{note.date}</time>
          </div>
          <div class="timeline-content">
            <p>{note.content}</p>
            {note.tags && (
              <div class="note-tags">
                {note.tags.map(tag => (
                  <span class="tag-badge">#{tag}</span>
                ))}
              </div>
            )}
          </div>
        </div>
      ))}
    </div>
  </section>
</Layout>

<style>
  .page-header {
    padding: 2rem 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    border-bottom: 1px solid var(--border-color);
    margin-bottom: 2.5rem;
  }

  .page-title {
    font-size: 2.5rem;
    font-weight: 800;
  }

  .page-subtitle {
    font-size: 1.1rem;
    color: var(--text-muted);
  }

  /* Timeline */
  .timeline {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .timeline-item {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
    position: relative;
  }

  @media (min-width: 640px) {
    .timeline-item {
      grid-template-columns: 140px 1fr;
      gap: 2rem;
    }
  }

  .timeline-date {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--primary-color);
    padding-top: 0.25rem;
  }

  .timeline-content {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 0.5rem;
    padding: 1.5rem;
    box-shadow: var(--card-shadow);
  }

  .timeline-content p {
    font-size: 1.02rem;
    line-height: 1.7;
    margin-bottom: 1rem;
    color: var(--text-color);
    white-space: pre-line;
  }

  .note-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag-badge {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--text-muted);
  }
</style>
